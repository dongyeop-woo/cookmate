{
  "expo": {
    "name": "요잘알",
    "slug": "rn-firebase-test",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/appIcon-padded.png",
    "userInterfaceStyle": "light",
    "scheme": "yojalal",
    "splash": {
      "image": "./assets/appIcon-padded.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "expo-dev-client",
      "@react-native-google-signin/google-signin",
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "4e6d0defa8992e8a7c49029d2f95ffb6",
          "kotlinVersion": "2.0.21"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "./plugins/withFirebaseFix",
      [
        "expo-notifications",
        {
          "icon": "./assets/appIcon-padded.png",
          "color": "#0B9A61"
        }
      ],
      "expo-speech-recognition",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8542314434357214~7155150061",
          "iosAppId": "ca-app-pub-8542314434357214~6880546845"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dyw.cookmate",
      "googleServicesFile": "./firebase/GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.879574205436-shfbj46e97a9n89fa133ggqtkgob25ec"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/appIcon-padded.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.dyw.cookmate",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/appIcon-padded.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "33929827-c46e-4676-989b-bda684d08b31"
      }
    }
  }
}
